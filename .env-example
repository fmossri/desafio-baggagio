# Desafio Full Stack - Gestão de Produtos
# --------------------------------------------------------------------------------

# App
APP_NAME=baggagio-challenge
DEBUG=false

# PostgreSQL (SQLAlchemy, psycopg v3)
# ------------------------------------------------------------------------------

# Dev DB Local
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/baggagio_db
# Test DB Local
TEST_DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/baggagio_test_db

# JWT
# ---------------------------------------------------------------------------------
JWT_SECRET_KEY=placeholder-de-chave-aleatoria-para-o-jwt
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# RabbitMQ
# ------------------------------------------------------------------------------
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Mensageria
# ------------------------------------------------------------------------------
MESSAGING_RETRY_TTL_MS=5000
MESSAGING_MAX_ATTEMPTS=8

# Outbox
# ------------------------------------------------------------------------------
OUTBOX_BATCH_SIZE=100
OUTBOX_POLL_INTERVAL_SECONDS=2

# CORS
# ------------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
CORS_ALLOW_CREDENTIALS=true

# Redis
# -------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# Rate Limiting
RATE_LIMIT_LOGIN_PER_MINUTE=10